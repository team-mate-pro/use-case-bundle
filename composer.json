{
    "name": "team-mate-pro/use-case-bundle",
    "description": "A building block for layered architecture with Symfony framework.",
  "version": "2.1.1",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": ">=7.0",
        "symfony/validator": ">=7.0",
        "symfony/security-bundle": ">=7.0",
        "symfony/serializer": ">=7.0",
        "team-mate-pro/contracts": "^1.2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brianium/paratest": "^7.0",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-phpunit": "*",
        "phpstan/phpstan-symfony": "*",
        "phpstan/extension-installer": "*",
        "squizlabs/php_codesniffer": "^3.10",
        "team-mate-pro/make": "^1.0",
        "team-mate-pro/tmp-standards": "^1.0",
        "team-mate-pro/tests-bundle": "^1.22",
        "symfony/console": ">=7.0",
        "symfony/yaml": ">=7.0",
        "symfony/http-kernel": ">=7.0",
        "symfony/var-exporter": ">=7.0"
    },
    "autoload": {
        "psr-4": {
            "TeamMatePro\\UseCaseBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TeamMatePro\\UseCaseBundle\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sebastian Twaróg",
            "email": "sebastian.twarog1989@gmail.com"
        }
    ],
    "scripts": {
        "phpunit": "APP_ENV=test ./vendor/bin/phpunit tests --testdox --colors=always",
        "tests:unit": "APP_ENV=test php bin/console tmp:tests --suite unit --no-warmup --coverage 100",
        "phpstan": "php vendor/phpstan/phpstan/phpstan analyse --memory-limit=1G",
        "phpstan:baseline": "php vendor/phpstan/phpstan/phpstan analyse --memory-limit=1G --generate-baseline",
        "phpcs": "@phpcs:check",
        "phpcs:check": "php vendor/bin/phpcs --exclude=Generic.Files.LineLength",
        "phpcs:fix": "php vendor/bin/phpcbf --exclude=Generic.Files.LineLength"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.3.0",
            "ext-simplexml": "8.3.0",
            "ext-xml": "8.3.0",
            "ext-dom": "8.3.0",
            "ext-xmlwriter": "8.3.0"
        }
    }
}
